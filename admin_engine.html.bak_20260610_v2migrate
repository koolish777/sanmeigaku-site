   S1()+'<b>強み（中心星）：</b>「'+f.chest+'」＝“'+f.chestTheme+'”。'+esc(f.chestBrief)+'　目上・組織は頭の星「'+f.head+'」（'+f.headTheme+'）。',
   S2()+'<b>仕事で活きる長所：</b>'+esc(f.shoiGood)+'　<span class="ad-note">（注意：'+esc(f.shoiBad)+'）</span>　追い風の色は'+f.honmeiColor+'。',
   S3()+'<b>生き方の軸（太陽星座）：</b><b>'+f.sunSid+'</b>＝“'+f.sunKey+'”。',
   '<b>整え：</b>集中を上げたいときは守護神の<b>'+f.shData.c+'</b>と'+f.shData.i+'を仕事まわりに。'
  ]),'⚠ 合否・採用結果・投資の成否は断定しない。「向き・活かし方」で伝える。',f,
  "【仕事】"+f.y+"/"+f.m+"/"+f.d+"\n"+f.total+"点/"+f.etype+"／中心星="+f.chest+"・頭="+f.head+"\n長所:"+f.shoiGood+"／追い風色="+f.honmeiColor+"\n太陽星座="+f.sunSid+"\n整え:"+f.shData.c+"/"+f.shData.i);
 }
 function renderHeart(f){
  topicCard("ax-heart","心の整え方 ─ 算命学 × 九星 × 占星 ─",ul([
   S1()+'<b>整え方の軸（守護神）：</b>足すとよいのは<b>'+f.shG+'</b>の気。色＝'+f.shData.c+'／小物＝'+f.shData.i+'／行動＝“'+f.shData.a+'”。',
   S3()+'<b>心のあり方（月星座）：</b><b>'+f.moonSid+'</b>＝“'+f.moonKey+'”。安心の場、月の宿は「'+f.nak+'」。',
   S2()+'<b>気づき：</b>本命星「'+f.honmei+'」の長所「'+esc(f.shoiGood)+'」を大切に。疲れると出やすいのは「'+esc(f.shoiBad)+'」—その日は守りに。',
   '<b>今日のセルフケア：</b>'+esc(f.luckyMsg)+'あわせたい色は'+f.lucky.c+'。'
  ]),'⚠ 医療・診断ではない。つらさが続くときは専門家・相談窓口をご案内する。',f,
  "【心の整え方】"+f.y+"/"+f.m+"/"+f.d+"\n守護神="+f.shG+"（色="+f.shData.c+"/小物="+f.shData.i+"/行動="+f.shData.a+"）\n月星座="+f.moonSid+"／月の宿="+f.nak+"\n長所:"+f.shoiGood+"／疲れ時:"+f.shoiBad+"\n今日:"+f.lucky.i+"/"+f.lucky.c);
 }

 function go(){
  var y=+$("ax-y").value,m=+$("ax-m").value,d=+$("ax-d").value;
  var dim=new Date(y,m,0).getDate(); if(d>dim){alert(y+"年"+m+"月は"+dim+"日までです。");return;}
  if(A.hasPartner()){var y2=+$("ax2-y").value,m2=+$("ax2-m").value,d2=+$("ax2-d").value,dm2=new Date(y2,m2,0).getDate(); if(d2>dm2){alert("お相手："+y2+"年"+m2+"月は"+dm2+"日までです。");return;}}
  var sex=(document.querySelector('input[name="ax-sex"]:checked')||{}).value||"f";
  try{ var f=A.compute(y,m,d,sex);
   A.renderDash(f);A.renderTalk(f);A.renderLetter(f);renderLove(f);renderRel(f);renderWork(f);renderHeart(f);
  }catch(e){ $("ax-dash").innerHTML='<div class="ad-card"><b>計算エラー：</b>'+esc(e.message)+'</div>'; }
 }
 function init(){
  var thisYear=new Date().getFullYear();
  function fillYMD(yS,mS,dS,blankYear){
   if(blankYear) yS.add(new Option("（未入力）",""));
   for(var i=thisYear;i>=1925;i--){yS.add(new Option(i+"年",i));}
   for(var mo=1;mo<=12;mo++){mS.add(new Option(mo+"月",mo));}
   for(var da=1;da<=31;da++){dS.add(new Option(da+"日",da));}
  }
  function fillHH(hS){hS.add(new Option("時刻不明","x")); for(var hr=0;hr<=23;hr++){hS.add(new Option(hr+"時",hr));}}
  function fillPref(pS){for(var pi=0;pi<PREF.length;pi++){pS.add(new Option(PREF[pi][0],pi));} pS.value=12;}
  fillYMD($("ax-y"),$("ax-m"),$("ax-d"),false); $("ax-y").value=1990;$("ax-m").value=1;$("ax-d").value=1;
  fillHH($("ax-hh")); $("ax-hh").value="x"; fillPref($("ax-pref"));
  fillYMD($("ax2-y"),$("ax2-m"),$("ax2-d"),true); $("ax2-y").value="";$("ax2-m").value=1;$("ax2-d").value=1;
  fillHH($("ax2-hh")); $("ax2-hh").value="x"; fillPref($("ax2-pref"));
  $("ax-go").onclick=go;
  var tabs=document.querySelectorAll('.ad-tabs button');
  tabs.forEach(function(b){ b.onclick=function(){
    tabs.forEach(function(x){x.classList.remove('on');}); b.classList.add('on');
    document.querySelectorAll('.ad-view').forEach(function(v){v.classList.remove('on');});
    $("ax-"+b.getAttribute('data-v')).classList.add('on');
  };});
  go();
 }
 if(document.readyState!=='loading') init(); else document.addEventListener('DOMContentLoaded',init);
})();

</script>
