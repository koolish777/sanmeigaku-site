function kippoTable(center,honmei,branch){
  const DIRNAMES=["北","北東","東","東南","南","南西","西","北西"];
  const TEII=[1,8,3,4,9,2,7,6];
  const BRD=[0,1,1,2,3,3,4,5,5,6,7,7];
  const stars=TEII.map(p=>((center+p-6)%9+9)%9+1);
  const gohoIdx=stars.indexOf(5);
  const haDir=BRD[(branch+6)%12];
  const honmeiIdx=stars.indexOf(honmei);
  return DIRNAMES.map((name,i)=>{
    const st=stars[i];
    let mark="−",why="";
    if(i===gohoIdx){mark="✕";why="五黄殺";}
    else if(gohoIdx>=0&&i===(gohoIdx+4)%8){mark="✕";why="暗剣殺";}
    else if(i===haDir){mark="✕";why="破";}
    else if(i===honmeiIdx){mark="✕";why="本命殺";}
    else if(honmeiIdx>=0&&i===(honmeiIdx+4)%8){mark="✕";why="本命的殺";}
    else if(st!==5&&aishou(st,honmei)){mark="◎";why="吉方";}
    return {name,star:st,mark,why};
  });
}
function kippoHtml(title,center,honmei,branch){
  const rows=kippoTable(center,honmei,branch);
  let h='<div style="margin-top:14px;"><b style="color:var(--accent-soft);font-size:0.9rem;">'+title+'（'+KYUSEI_SHORT[center-1]+'中宮）</b>';
  h+='<table class="un"><tr>'+rows.map(r=>'<th>'+r.name+'</th>').join('')+'</tr>';
  h+='<tr>'+rows.map(r=>'<td>'+KYUSEI_SHORT[r.star-1]+'</td>').join('')+'</tr>';
  h+='<tr>'+rows.map(r=>'<td>'+(r.mark==="◎"?'<span style="color:var(--accent);font-weight:bold;">◎</span>':(r.mark==="✕"?'<span style="color:#999;">✕</span>':'−'))+'</td>').join('')+'</tr>';
  h+='<tr>'+rows.map(r=>'<td style="font-size:0.7rem;color:#7a6f5d;">'+(r.why||'')+'</td>').join('')+'</tr></table></div>';
  return h;
}

