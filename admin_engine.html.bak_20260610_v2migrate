function solsticeJdn(cy,summer){
  const target=summer?90:270,am=summer?6:12,ad=summer?21:22;
  let lo=jdn(cy,am,ad)-0.5-8,hi=lo+16;
  const f=j=>(((sunLon(j)-target+540)%360)-180);
  for(let i=0;i<50;i++){const mid=(lo+hi)/2;if(f(mid)<0)lo=mid;else hi=mid;}
  const t=jdToDateJST((lo+hi)/2);
  return jdn(t.y,t.m,t.d);
}
function nineStarDay(y,m,d){
  const myJ=jdn(y,m,d);
  let cur=null;
  for(let yy=y-2;yy<=y;yy++){
    for(const summer of [false,true]){
      const sj=solsticeJdn(yy,summer);
      const r=((sj+49)%60+60)%60;
      const delta=(60-r)%60;
      const c1=sj+delta,c2=sj+delta-60;
      const anchor=(c1-sj<=sj-c2)?c1:c2;
      if(anchor<=myJ&&(!cur||anchor>cur.j))cur={j:anchor,yang:!summer};
    }
  }
  const diff=myJ-cur.j;
  return cur.yang?(diff%9)+1:9-(diff%9);
}
