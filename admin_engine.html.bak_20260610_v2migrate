function keplerE(M,e){let E=M;for(let i=0;i<20;i++){E=M+e*Math.sin(E);}return E;}
function helioPos(el,T){
  const rad=Math.PI/180;
  const a=el[0]+el[1]*T,e=el[2]+el[3]*T,I=(el[4]+el[5]*T)*rad,L=el[6]+el[7]*T,wbar=el[8]+el[9]*T,O=(el[10]+el[11]*T)*rad;
  const M=(((L-wbar)%360+360)%360)*rad, w=wbar*rad-O;
  const E=keplerE(M,e);
  const xv=a*(Math.cos(E)-e), yv=a*Math.sqrt(1-e*e)*Math.sin(E);
  const v=Math.atan2(yv,xv), r=Math.sqrt(xv*xv+yv*yv);
  return [
    r*(Math.cos(O)*Math.cos(v+w)-Math.sin(O)*Math.sin(v+w)*Math.cos(I)),
    r*(Math.sin(O)*Math.cos(v+w)+Math.cos(O)*Math.sin(v+w)*Math.cos(I)),
    r*Math.sin(v+w)*Math.sin(I)
  ];
}
