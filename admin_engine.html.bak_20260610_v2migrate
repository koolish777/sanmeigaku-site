function branchRels(a,b){
  const out=[];
  if(a!==b&&((a+b===1)||(a+b===13)))out.push("支合");
  if((a-b+12)%12===6)out.push("対冲");
  for(const t of SANGO){if(a!==b&&t.includes(a)&&t.includes(b))out.push("半会");}
  for(const t of HOSANI){if(a!==b&&t.includes(a)&&t.includes(b))out.push("方三位");}
  const KEI=[[2,5],[5,8],[2,8],[1,10],[10,7],[1,7],[0,3]];
  if(KEI.some(p=>(p[0]===a&&p[1]===b)||(p[0]===b&&p[1]===a)))out.push("刑");
  if(a===b&&[4,6,9,11].includes(a))out.push("自刑");
  const GAI=[[0,7],[1,6],[2,5],[3,4],[8,11],[9,10]];
  if(GAI.some(p=>(p[0]===a&&p[1]===b)||(p[0]===b&&p[1]===a)))out.push("害");
  const HA=[[0,9],[1,4],[2,11],[3,6],[5,8],[10,7]];
  if(HA.some(p=>(p[0]===a&&p[1]===b)||(p[0]===b&&p[1]===a)))out.push("破");
  return out;
}
function pillarRels(i1,i2){
